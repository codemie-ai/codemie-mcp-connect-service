# ==============================================================================
# .dockerignore for MCP Connect Service (Python)
# ==============================================================================
# Excludes unnecessary files from Docker build context for faster builds
# and smaller image sizes

# ==============================================================================
# Python artifacts
# ==============================================================================
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.coverage
htmlcov/

# ==============================================================================
# Virtual environments (excluded - built inside Docker)
# ==============================================================================
.venv/
venv/
env/
ENV/

# ==============================================================================
# Git and CI/CD
# ==============================================================================
.git/
.github/
.gitignore
.gitattributes
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml

# ==============================================================================
# Documentation and tests (not needed in production image)
# ==============================================================================
docs/
tests/
*.md
!README.md

# ==============================================================================
# Development and IDE files
# ==============================================================================
.env
.env.*
!.env.example
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ==============================================================================
# BMM workflows and Claude Code
# ==============================================================================
bmad/
.claude/
.codemie/

# ==============================================================================
# Docker files (not needed inside container)
# ==============================================================================
Dockerfile*
.dockerignore
docker-compose*.yml

# ==============================================================================
# Deployment templates (applied externally via Helm)
# ==============================================================================
deploy-templates/

# ==============================================================================
# Log files and temporary files
# ==============================================================================
*.log
logs/
*.sqlite
*.db

# ==============================================================================
# Miscellaneous
# ==============================================================================
example_requests.http
patterns.txt
buildx-*
