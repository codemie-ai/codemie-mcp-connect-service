# Core Configuration
ACCESS_TOKEN=                                    # Bearer token for API authentication (required for production)
PORT=3000                                        # HTTP server port (used by Docker and start-with-ngrok.sh)

# Logging Configuration
LOG_LEVEL=info                                   # Logging verbosity: debug, info, warning, error, critical
LOG_FORMAT=text                                  # Logging format: json (production) or text (development)
DEBUG_LOG_BRIDGE_PAYLOAD=false                   # Log complete bridge payload at debug level (true/false, default: false)

# MCP Client Configuration
MCP_CONNECT_INIT_TIMEOUT=30000                    # MCP session initialization timeout in milliseconds (30 seconds)
MCP_CONNECT_DEFAULT_TIMEOUT=120000                # Default timeout for MCP method invocations in milliseconds (2 minutes)
MCP_CONNECT_CLIENT_CACHE_TTL=300000              # Client cache TTL in milliseconds (5 minutes)
MCP_CONNECT_CACHE_CLEANUP_INTERVAL=60000         # Cleanup scheduler interval in milliseconds (1 minute)
MCP_CONNECT_HTTP_TIMEOUT=30000                   # HTTP connection timeout for streamable-http/SSE in milliseconds (30 seconds)
MCP_CONNECT_SSE_READ_TIMEOUT=300000              # SSE read timeout for long-polling connections in milliseconds (5 minutes)

# Ngrok Tunnel (Docker Deployment)
NGROK_AUTHTOKEN=                                 # Ngrok authentication token for public tunnel
NGROK_DOMAIN=                                    # Optional reserved ngrok domain (e.g., https://my-app.ngrok.app)